# Supported Properties
# - indent_style
# - indent_size
# - tab_width
# - end_of_line
# - charset
# - trim_trailing_whitespace
# - insert_final_newline
# - root

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true

[*.{yml,yaml}]
indent_size = 2
indent_style = space
trim_trailing_whitespace = true

[*.{json,jsonc}]
indent_size = 2
indent_style = space
trim_trailing_whitespace = true

[*.md]
indent_size = 2
indent_style = space
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
trim_trailing_whitespace = true

[*.toml]
indent_size = 2
indent_style = space
trim_trailing_whitespace = true

[*.sh]
indent_size = 2
indent_style = space
trim_trailing_whitespace = true

[*.{html,jsx,tsx}]
indent_size = 2
indent_style = space
trim_trailing_whitespace = true

[*.{css,scss}]
indent_size = 2
indent_style = space
trim_trailing_whitespace = true

[*.{js,ts}]
indent_size = 2
indent_style = space
trim_trailing_whitespace = true

[*.go]
indent_style = tab
trim_trailing_whitespace = true

[*.rs]
indent_size = 4
indent_style = space
trim_trailing_whitespace = true

[*.py]
indent_size = 4
indent_style = space
trim_trailing_whitespace = true

[*.php]
indent_size = 4
indent_style = space
trim_trailing_whitespace = true

[*.{rb,erb}]
indent_size = 2
indent_style = space
trim_trailing_whitespace = true

[Dockerfile]
indent_size = 4
indent_style = space
trim_trailing_whitespace = true